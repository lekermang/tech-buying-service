{
  "tests": [
    {
      "name": "Reset check - account not found",
      "method": "POST",
      "path": "/?action=reset_check",
      "body": {"phone": "+70000000000", "name": "Несуществующий"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт не найден. Проверьте телефон и имя."},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login - account not found",
      "method": "POST",
      "path": "/?action=login",
      "body": {"phone": "+70000000000", "password": "wrongpassword"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт с этим номером не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me unauthorized",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    }
  ]
}