{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"phone": "+79001119988", "name": "Тест DzChat", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"phone": "+79001119988", "password": "wrongpassword"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me unauthorized",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    }
  ]
}
