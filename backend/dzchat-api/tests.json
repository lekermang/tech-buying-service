{
  "tests": [
    {
      "name": "Reset check - account not found",
      "method": "POST",
      "path": "/?action=reset_check",
      "body": {"phone": "+70000000000", "name": "Несуществующий"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт не найден. Проверьте телефон и имя."},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login - account not found",
      "method": "POST",
      "path": "/?action=login",
      "body": {"phone": "+70000000000", "password": "wrongpassword"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Аккаунт с этим номером не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me unauthorized",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Typing unauthorized",
      "method": "POST",
      "path": "/?action=typing",
      "body": {"chat_id": 1, "is_typing": true},
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Call end unauthorized",
      "method": "POST",
      "path": "/?action=call_end",
      "body": {"call_id": 1},
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "VAPID public key",
      "method": "GET",
      "path": "/?action=vapid_public_key",
      "expectedStatus": 200,
      "expectedBody": {"ready": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Push subscribe unauthorized",
      "method": "POST",
      "path": "/?action=push_subscribe",
      "body": {"subscription": {}},
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    }
  ]
}